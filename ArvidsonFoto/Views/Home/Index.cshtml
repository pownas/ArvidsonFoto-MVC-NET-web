@using ArvidsonFoto.Core.Interfaces
@*<!-- Home-Index (Startsidan) -->*@
@model ArvidsonFoto.Core.ViewModels.GalleryViewModel

@section MetaData {
    <meta name="robots" content="noimageindex" />
    <meta name="description" content="Torbjörn Arvidson Foto - Välkommen till mitt bildarkiv. Bilder på djur och natur." />
    <link rel="canonical" href="https://ArvidsonFoto.se/" />
}

<div id="page-header">
    <h2>Torbjörn Arvidson Foto <small>Välkommen till mitt bildarkiv</small></h2>
</div>

<div id="page-content" class="row">
    <div class="col-xs-12 col-sm-5">
        <p>Här finner du ett urval av mina bilder.</p>
        <p>
            Är du intresserad av att köpa högupplösta bilder? <br>
            Kontakta mig på <a href="mailto:torbjorn_arvidson@hotmail.com">torbjorn_arvidson@hotmail.com</a>.
        </p>
        <p><i>/Torbjörn Arvidson</i></p>
        <div class="text-center text-md-left">
            <figure class="figure alert alert-light" title="Torbjörn Arvidson">
                <img class="figure-img img-fluid rounded" width="420" height="420" src="./img/Torbjorn2020.jpg" alt="Bild av: Torbjörn Arvidson" title="Torbjörn Arvidson" />
                <figcaption class="figure-caption text-center text-truncate">Torbjörn Arvidson</figcaption>
            </figure>
            <div class="text-center mt-2">
                <a href="/Info/Om_mig" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-question-circle"></i> Läs mer om mig
                </a>
            </div>
        </div>
    </div>
    <div id="page-gallery" class="mt-3 col-12 col-sm-7">
        <partial name="../Bilder/_GalleryStartpage" model="Model" />
        <div class="text-center">
            <small>Slumpmässigt utvalda bilder</small>
        </div>
    </div><!-- /end-gallery -->
</div>

@* News Feed Section *@
@if (ViewBag.LatestNews != null && ((List<TblNews>)ViewBag.LatestNews).Count > 0)
{
    <div class="row mt-5">
        <div class="col-12">
            <h3><i class="bi bi-newspaper"></i> Senaste nyheterna</h3>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
                @foreach (var news in (List<TblNews>)ViewBag.LatestNews)
                {
                    <div class="col mb-3">
                        <a href="/Nyheter/@news.NewsId" class="news-card-link">
                            <div class="card news-card h-100">
                                <div class="card-header bg-dark text-white">
                                    <h6 class="card-title mb-0">@news.NewsTitle</h6>
                                    <small class="text-secondary">@news.NewsCreated?.ToString("yyyy-MM-dd HH:mm") av @news.NewsAuthor</small>
                                </div>
                                <div class="card-body bg-light">
                                    <p class="card-text text-dark">
                                        @if (!string.IsNullOrEmpty(news.NewsSummary))
                                        {
                                            @news.NewsSummary
                                        }
                                        else
                                        {
                                            @Html.Raw(news.NewsContent.Length > 100 ? news.NewsContent.Substring(0, 100) + "..." : news.NewsContent)
                                        }
                                    </p>
                                    <small class="text-secondary">@news.NewsCreated?.ToString("yyyy-MM-dd")</small>
                                </div>
                                <div class="card-footer bg-primary text-white">
                                    <small>Läs mer <i class="bi bi-arrow-right"></i></small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
            <div class="text-center mt-3">
                <a href="/Nyheter" class="btn btn-primary">
                    <i class="bi bi-newspaper"></i> Visa alla nyheter
                </a>
            </div>
        </div>
    </div>
}

<!-- Promotional boxes (puffar) -->
<div class="row mt-5 mb-4">
    <div class="col-12">
        <h3 class="text-center mb-4">Utforska mer</h3>
    </div>
    <div class="col-12 col-md-6 mb-3">
        <div class="card puff-card h-100">
            <div class="card-body text-center">
                <i class="bi bi-camera puff-icon"></i>
                <h4 class="card-title mt-3">Senast fotograferade</h4>
                <p class="card-text">Upptäck de nyaste bilderna i samlingen. <br /> Se vad som har fotograferats senast och utforska de färskaste tillskotten.</p>
                <a href="/Senast/Fotograferad" class="btn btn-outline-primary">
                    <i class="bi bi-camera"></i> Se senaste bilderna
                </a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 mb-3">
        <div class="card puff-card h-100">
            <div class="card-body text-center">
                <i class="bi bi-grid-3x3-gap puff-icon"></i>
                <h4 class="card-title mt-3">Alla kategorier</h4>
                <p class="card-text">Bläddra bland bildkategorier och se de senaste bilderna per kategori. <br /> Hitta snabbt det du letar efter.</p>
                <a href="/Senast/Per%20kategori" class="btn btn-outline-primary">
                    <i class="bi bi-grid-3x3-gap"></i> Visa alla kategorier
                </a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 mb-3">
        <div class="card puff-card h-100">
            <div class="card-body text-center">
                <i class="bi bi-cart3 puff-icon"></i>
                <h4 class="card-title mt-3">Köp av bilder</h4>
                <p class="card-text">Intresserad av att köpa högupplösta bilder?<br /> Ta kontakt för mer information om priser och användningsområden.</p>
                <a href="/Info/Kop_av_bilder" class="btn btn-outline-primary">
                    <i class="bi bi-cart3"></i> Läs mer om bildköp
                </a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 mb-3">
        <div class="card puff-card h-100">
            <div class="card-body text-center">
                <i class="bi bi-diagram-3 puff-icon"></i>
                <h4 class="card-title mt-3">Sidkarta</h4>
                <p class="card-text">Hitta snabbt till alla bildkategorier och sidor på webbplatsen. <br /> En komplett översikt över allt innehåll.</p>
                <a href="/Info/Sidkarta" class="btn btn-outline-primary">
                    <i class="bi bi-diagram-3"></i> Visa sidkarta
                </a>
            </div>
        </div>
    </div>
</div>
