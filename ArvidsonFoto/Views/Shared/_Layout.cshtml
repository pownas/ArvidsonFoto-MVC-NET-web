<!DOCTYPE html>
<html lang="sv-se" data-bs-theme="light">
<head>
    <!-- Character encoding -->
    <meta charset="utf-8" />
    <!-- Viewport for responsive design -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Site version and last modified content -->
    @{
        var appVersion = typeof(ArvidsonFoto.Controllers.HomeController).Assembly
            .GetCustomAttributes(typeof(System.Reflection.AssemblyInformationalVersionAttribute), inherit: false)
            .Cast<System.Reflection.AssemblyInformationalVersionAttribute>()
            .FirstOrDefault()
            ?.InformationalVersion ?? "unknown";

        var assemblyPath = typeof(ArvidsonFoto.Controllers.HomeController).Assembly.Location;
        var lastModifiedUtc = !string.IsNullOrWhiteSpace(assemblyPath) && System.IO.File.Exists(assemblyPath)
            ? System.IO.File.GetLastWriteTimeUtc(assemblyPath)
            : DateTime.UtcNow;
    }
    <meta name="ArvidsonFoto-version" content="Build: v@appVersion - Tag: https://github.com/pownas/ArvidsonFoto-MVC-NET-web/releases/tag/v@(appVersion)" />
    <meta name="last-modified" content="@lastModifiedUtc.ToString("yyyy-MM-ddTHH:mm:ss'Z'")">
    <partial name="_MetaData" />
    @await RenderSectionAsync("MetaData", required: false)
    <title>@ViewData["Title"] - ArvidsonFoto.se</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/site.min.css" /> @*<!-- Se info i "wwwroot/css/site.scss" för alla CSS-imports... -->*@
</head>
<body>
    <header>
        <partial name="_NavBar" />
    </header>
    <main class="container-md pb-5">
        @RenderBody()
    </main>
    <footer class="footer overridden-footer">
        <div class="container">
            <partial name="_Footer" />
        </div>
    </footer>
    <script src="lib/jquery/dist/jquery.min.js"></script> @*<!-- version: 3.5.1 - Required for jQuery.smartmenus and other plugins -->*@
    <script src="lib/bootstrap/js/bootstrap.bundle.min.js"></script> @*<!-- version: 5.3.3-dist (includes Popper v2, no longer requires jQuery) -->*@
    <script src="lib/jQuery.smartmenus/jquery.smartmenus.min.js"></script> @*<!-- version: 1.1.1 -->*@
    <script src="lib/jQuery.smartmenus/smartmenu.js"></script> @*<!-- version: 1.1.1 -->*@
    <script src="lib/glightbox/js/glightbox.min.js"></script> @*<!-- version: 3.0.7 -->*@
    <script src="js/gLightBoxOptions.js"></script> @*<!-- Egna inställningar till glightbox -->*@
    <script src="js/categoryCache.js"></script> @*<!-- Client-side category caching with localStorage -->*@
    <script src="js/categoryTooltip.js"></script> @*<!-- Category tooltip with image preview -->*@
    <script src="js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>